FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

convertToMeters 1;

// Paper case-study room geometry:
// W x L x H = 4 m x 7 m x 3 m
// Here we use:
// x = length = 7 m  (west -> east)
// y = width  = 4 m
// z = height = 3 m
//
// The paper states openings are on east and west walls,
// but their width/height are to be evaluated.
// So this mesh uses one centered opening on each side as a tunable starting point.

// The vertices use a (X Y Z) coordinate format. The "//" out to the side labels each vertex by a number.
// This vertex label is then used in the blocks section.

vertices
(
    (0    0    0)   // 0
    (0    1.25 0)   // 1
    (0    2.75 0)   // 2
    (0    4    0)   // 3

    (0    0    0.5) // 4
    (0    1.25 0.5) // 5
    (0    2.75 0.5) // 6
    (0    4    0.5) // 7

    (0    0    2.0) // 8
    (0    1.25 2.0) // 9
    (0    2.75 2.0) // 10
    (0    4    2.0) // 11

    (0    0    3.0) // 12
    (0    1.25 3.0) // 13
    (0    2.75 3.0) // 14
    (0    4    3.0) // 15

    (7    0    0)   // 16
    (7    1.25 0)   // 17
    (7    2.75 0)   // 18
    (7    4    0)   // 19

    (7    0    0.5) // 20
    (7    1.25 0.5) // 21
    (7    2.75 0.5) // 22
    (7    4    0.5) // 23

    (7    0    2.0) // 24
    (7    1.25 2.0) // 25
    (7    2.75 2.0) // 26
    (7    4    2.0) // 27

    (7    0    3.0) // 28
    (7    1.25 3.0) // 29
    (7    2.75 3.0) // 30
    (7    4    3.0) // 31
);

// Block are defined here as hexadral blocks (rectangular prisms).
// Three parts to a block:
// First four points (vertices) in the hex defines the bottom face.
// Second four points (vertices) in the hex defines the top face.
// Then the second argument of three points defines the number of cells in the X, Y, and Z directions.
// Then simpleGrading defines the stretching or compression of cells in the X, Y, and Z directions.
// For simpleGrading 1 implies no stretching or compression, i.e. uniform spacing.

blocks
(
    // Blocks 1 through 3.
    hex (0 16 17 1 4 20 21 5)   (70 12 10) simpleGrading (1 1 1)
    hex (1 17 18 2 5 21 22 6)   (70 15 10) simpleGrading (1 1 1)
    hex (2 18 19 3 6 22 23 7)   (70 12 10) simpleGrading (1 1 1)

    // Blocks 4 through 6.
    hex (4 20 21 5 8 24 25 9)   (70 12 30) simpleGrading (1 1 1)
    hex (5 21 22 6 9 25 26 10)  (70 15 30) simpleGrading (1 1 1)
    hex (6 22 23 7 10 26 27 11) (70 12 30) simpleGrading (1 1 1)

    // Blocks 7 through 9.
    hex (8 24 25 9 12 28 29 13)   (70 12 20) simpleGrading (1 1 1)
    hex (9 25 26 10 13 29 30 14)  (70 15 20) simpleGrading (1 1 1)
    hex (10 26 27 11 14 30 31 15) (70 12 20) simpleGrading (1 1 1)
);

// Use edges if there are non-linear segments to be connected in the geometry.

edges
(
);

